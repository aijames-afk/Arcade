const MultiplayerLobby = ({ user, activeGame, showToast }) => {
  const [roomCode, setRoomCode] = useState('');
  const [activeRoom, setActiveRoom] = useState(null);
  const [joining, setJoining] = useState(false);

  const handleCreateRoom = async () => {
    const code = Math.random().toString(36).substring(2, 8).toUpperCase();
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'rooms', code), {
      gameId: activeGame.id, hostId: user.uid, players: [user.uid], status: 'waiting', createdAt: Date.now()
    });
    setActiveRoom(code);
    showToast("Room Created!");
  };

  const handleJoinRoom = async () => {
    if (!roomCode) return;
    setJoining(true);
    const roomRef = doc(db, 'artifacts', appId, 'public', 'data', 'rooms', roomCode.toUpperCase());
    try {
      await updateDoc(roomRef, { players: arrayUnion(user.uid), status: 'ready' });
      setActiveRoom(roomCode.toUpperCase());
    } catch (e) { showToast("Room Not Found"); }
    finally { setJoining(false); }
  };

  if (activeRoom) {
    return (
      <div className="text-center animate-in zoom-in">
        <div className="bg-slate-950 p-8 rounded-[2rem] border-2 border-blue-500/20 mb-6">
          <p className="text-xs font-black text-slate-500 uppercase tracking-widest mb-1">Invite Code</p>
          <p className="text-5xl font-mono font-black text-blue-400 tracking-tighter">{activeRoom}</p>
        </div>
        <button 
          onClick={() => {
            navigator.clipboard.writeText(activeRoom);
            showToast("Code Copied!");
          }}
          className="flex items-center gap-2 mx-auto bg-blue-600 px-8 py-3 rounded-xl font-black hover:bg-blue-500 transition-all"
        >
          <Copy size={18}/> Copy Code
        </button>
      </div>
    );
  }

  return (
    <div className="flex flex-col gap-4 w-full max-w-xs">
      <button onClick={handleCreateRoom} className="bg-blue-600 p-5 rounded-2xl font-black text-xl shadow-xl hover:-translate-y-1 transition-all">Create Room</button>
      <div className="flex gap-2">
        <input value={roomCode} onChange={e=>setRoomCode(e.target.value.toUpperCase())} placeholder="CODE" className="bg-slate-950 border border-slate-800 p-4 rounded-xl flex-1 text-center font-mono font-bold"/>
        <button onClick={handleJoinRoom} className="bg-slate-800 px-6 rounded-xl font-black">{joining ? <Activity className="animate-spin"/> : <LogIn/>}</button>
      </div>
    </div>
  );
};

