/**
 * ENGINE: SIM-X (The Universal Simulation Engine)
 */
const SimXEngine = ({ game, onWin }) => {
  const [score, setScore] = useState(0);
  const [isPlaying, setIsPlaying] = useState(false);
  const [timer, setTimer] = useState(30);
  const [targetPos, setTargetPos] = useState({ x: 50, y: 50 });
  
  const startGame = () => {
    setIsPlaying(true);
    setScore(0);
    setTimer(30);
    moveTarget();
  };

  const moveTarget = () => {
    setTargetPos({ 
      x: 10 + Math.random() * 80, 
      y: 10 + Math.random() * 80 
    });
  };

  const handleClick = () => {
    if (!isPlaying) return;
    setScore(s => s + 10);
    moveTarget();
  };

  useEffect(() => {
    let interval;
    if (isPlaying && timer > 0) {
      interval = setInterval(() => setTimer(t => t - 1), 1000);
    } else if (timer === 0) {
      setIsPlaying(false);
      onWin(Math.floor(score / 5));
    }
    return () => clearInterval(interval);
  }, [isPlaying, timer]);

  const getThemeColor = () => {
    if (game.id.includes('Space')) return 'bg-indigo-600';
    if (game.id.includes('Dungeon')) return 'bg-red-900';
    if (game.id.includes('Kart')) return 'bg-yellow-500';
    return 'bg-blue-600';
  };

  return (
    <div className="w-full max-w-xl flex flex-col items-center gap-6">
      <div className="flex justify-between w-full font-black text-xl px-4">
        <span className="text-blue-400">SCORE: {score}</span>
        <span className={timer < 10 ? 'text-red-500 animate-pulse' : 'text-slate-500'}>TIME: {timer}s</span>
      </div>
      
      <div 
        className={`w-full aspect-video rounded-3xl relative overflow-hidden border-4 border-slate-800 bg-slate-950 cursor-crosshair`}
        onClick={handleClick}
      >
        <div className="absolute inset-0 opacity-20 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]" />
        
        {isPlaying ? (
          <div 
            className={`absolute w-12 h-12 rounded-full flex items-center justify-center transition-all duration-200 shadow-2xl ${getThemeColor()}`}
            style={{ left: `${targetPos.x}%`, top: `${targetPos.y}%`, transform: 'translate(-50%, -50%)' }}
          >
            {game.icon}
          </div>
        ) : (
          <div className="absolute inset-0 flex flex-col items-center justify-center bg-slate-900/80 backdrop-blur-sm p-6 text-center">
            <h3 className="text-2xl font-black mb-4 uppercase">{game.name}</h3>
            <button onClick={startGame} className="bg-blue-600 px-10 py-4 rounded-2xl font-black text-xl hover:scale-105 transition-transform shadow-xl">
              {timer === 0 ? 'PLAY AGAIN' : 'START SIMULATION'}
            </button>
            {timer === 0 && <p className="mt-4 text-yellow-500 font-black tracking-widest">SESSION EARNED: {Math.floor(score / 5)} COINS</p>}
          </div>
        )}
      </div>
      <p className="text-slate-500 text-xs font-bold uppercase tracking-widest text-center px-8">
        Sim-X Environment: Click the target to earn coins!
      </p>
    </div>
  );
};

const SnakeGame = ({ onWin }) => {
  const [snake, setSnake] = useState([{ x: 10, y: 10 }]);
  const [food, setFood] = useState({ x: 5, y: 5 });
  const [dir, setDir] = useState({ x: 0, y: -1 });
  const [isGameOver, setIsGameOver] = useState(false);
  const [score, setScore] = useState(0);

  const moveSnake = useCallback(() => {
    if (isGameOver) return;
    setSnake(prev => {
      const head = { x: prev[0].x + dir.x, y: prev[0].y + dir.y };
      if (head.x < 0 || head.x >= 20 || head.y < 0 || head.y >= 20 || prev.some(s => s.x === head.x && s.y === head.y)) {
        setIsGameOver(true);
        if (score > 0) onWin(score * 5);
        return prev;
      }
      const newSnake = [head, ...prev];
      if (head.x === food.x && head.y === food.y) {
        setScore(s => s + 1);
        setFood({ x: Math.floor(Math.random() * 20), y: Math.floor(Math.random() * 20) });
      } else {
        newSnake.pop();
      }
      return newSnake;
    });
  }, [dir, food, isGameOver, score, onWin]);

  useEffect(() => {
    const handleKey = (e) => {
      if (e.key === 'ArrowUp' && dir.y === 0) setDir({ x: 0, y: -1 });
      if (e.key === 'ArrowDown' && dir.y === 0) setDir({ x: 0, y: 1 });
      if (e.key === 'ArrowLeft' && dir.x === 0) setDir({ x: -1, y: 0 });
      if (e.key === 'ArrowRight' && dir.x === 0) setDir({ x: 1, y: 0 });
    };
    window.addEventListener('keydown', handleKey);
    const interval = setInterval(moveSnake, 150);
    return () => { window.removeEventListener('keydown', handleKey); clearInterval(interval); };
  }, [moveSnake, dir]);

  return (
    <div className="flex flex-col items-center gap-4">
      <div className="text-xl font-black text-blue-400">Score: {score}</div>
      <div className="grid grid-cols-20 grid-rows-20 bg-slate-950 border-4 border-slate-800 rounded-lg overflow-hidden" style={{ width: '300px', height: '300px', display: 'grid', gridTemplateColumns: 'repeat(20, 1fr)' }}>
        {Array.from({ length: 400 }).map((_, i) => {
          const x = i % 20;
          const y = Math.floor(i / 20);
          const isSnake = snake.some(s => s.x === x && s.y === y);
          const isFood = food.x === x && food.y === y;
          return <div key={i} className={`w-full h-full ${isSnake ? 'bg-blue-500' : isFood ? 'bg-rose-500 animate-pulse' : ''}`} />;
        })}
      </div>
      {isGameOver && <button onClick={() => { setSnake([{x:10,y:10}]); setIsGameOver(false); setScore(0); }} className="bg-blue-600 px-6 py-2 rounded-full font-bold">Try Again</button>}
    </div>
  );
};

const ReactionTrainer = ({ onWin }) => {
  const [state, setState] = useState('waiting');
  const [startTime, setStartTime] = useState(0);
  const [result, setResult] = useState(0);
  const timerRef = useRef(null);

  const start = () => {
    setState('ready');
    timerRef.current = setTimeout(() => {
      setStartTime(Date.now());
      setState('click');
    }, 2000 + Math.random() * 3000);
  };

  const handleClick = () => {
    if (state === 'ready') { clearTimeout(timerRef.current); setState('waiting'); }
    else if (state === 'click') {
      const diff = Date.now() - startTime;
      setResult(diff);
      setState('result');
      if (diff < 400) onWin(Math.max(5, Math.floor(1000/diff) * 2));
    }
  };

  return (
    <div onClick={state === 'waiting' || state === 'result' ? start : handleClick} className={`w-full max-w-md h-64 rounded-[2rem] flex items-center justify-center cursor-pointer transition-colors border-4 ${state === 'ready' ? 'bg-rose-600 border-rose-500' : state === 'click' ? 'bg-green-500 border-green-400' : 'bg-slate-800 border-slate-700'}`}>
      <div className="text-2xl font-black text-center px-4">
        {state === 'waiting' && 'TAP TO START'}
        {state === 'ready' && 'WAIT FOR GREEN...'}
        {state === 'click' && 'TAP NOW!'}
        {state === 'result' && `${result}ms! TAP TO RETRY`}
      </div>
    </div>
  );
};

