export default function App() {
  const [user, setUser] = useState(null);
  const [coins, setCoins] = useState(0);
  const [unlocked, setUnlocked] = useState(['react', 'm-ttt', 'm-rps']);
  const [activeGame, setActiveGame] = useState(null);
  const [toast, setToast] = useState(null);

  useEffect(() => {
    const initAuth = async () => {
      if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
        await signInWithCustomToken(auth, __initial_auth_token);
      } else {
        await signInAnonymously(auth);
      }
    };
    initAuth();
    return onAuthStateChanged(auth, setUser);
  }, []);

  useEffect(() => {
    if (!user) return;
    const userRef = doc(db, 'artifacts', appId, 'public', 'data', 'players', user.uid);
    return onSnapshot(userRef, (snap) => {
      if (snap.exists()) {
        const d = snap.data();
        setCoins(d.coins ?? 0);
        setUnlocked(d.unlocked ?? ['react', 'm-ttt', 'm-rps']);
      } else {
        setDoc(userRef, { coins: 100, unlocked: ['react', 'm-ttt', 'm-rps'] });
      }
    }, (err) => console.error(err));
  }, [user]);

  const showToast = (msg) => {
    setToast(msg);
    setTimeout(() => setToast(null), 3000);
  };

  const handleWin = async (amt) => {
    if (!user || amt <= 0) return;
    const userRef = doc(db, 'artifacts', appId, 'public', 'data', 'players', user.uid);
    await updateDoc(userRef, { coins: increment(amt) });
    showToast(`Earned +${amt} Coins!`);
  };

  const handleBuy = async (game) => {
    if (coins < game.price) {
      showToast(`Need ${game.price - coins} more coins!`);
      return;
    }
    const userRef = doc(db, 'artifacts', appId, 'public', 'data', 'players', user.uid);
    await updateDoc(userRef, { coins: increment(-game.price), unlocked: arrayUnion(game.id) });
    showToast(`Unlocked ${game.name}!`);
  };

  if (!user) return <div className="min-h-screen bg-slate-950 flex items-center justify-center text-blue-500 font-black animate-pulse">LOADING ARCADE...</div>;

  return (
    <div className="min-h-screen bg-slate-950 text-slate-100 font-sans selection:bg-blue-500/30">
      {toast && (
        <div className="fixed top-24 left-1/2 -translate-x-1/2 z-[100] bg-blue-600 px-8 py-3 rounded-full shadow-2xl animate-in zoom-in slide-in-from-top-4 font-black flex items-center gap-2">
          <Zap size={18} fill="currentColor"/> {toast}
        </div>
      )}

      <nav className="sticky top-0 z-50 bg-slate-950/80 backdrop-blur-md border-b border-white/5 px-6 py-4 flex items-center justify-between">
        <div className="flex items-center gap-3 cursor-pointer" onClick={() => setActiveGame(null)}>
          <div className="bg-blue-600 p-2 rounded-xl"><Zap className="text-white" fill="currentColor" size={20}/></div>
          <h1 className="text-xl font-black tracking-tighter uppercase">Arcade<span className="text-blue-500">Pro</span></h1>
        </div>
        <div className="bg-slate-900 px-4 py-2 rounded-full border border-white/5 flex items-center gap-3">
          <Coins className="text-yellow-500" size={18}/>
          <span className="font-mono font-bold text-yellow-400">{coins}</span>
        </div>
      </nav>

      <main className="max-w-7xl mx-auto p-6">
        {activeGame ? (
          <div className="animate-in fade-in slide-in-from-bottom-4">
            <button onClick={() => setActiveGame(null)} className="flex items-center gap-2 text-slate-500 hover:text-white mb-6 font-bold transition-colors">
              <Home size={18}/> Back to Lobby
            </button>
            <div className="bg-slate-900 border border-white/5 rounded-[3rem] p-8 sm:p-12 min-h-[500px] flex flex-col items-center justify-center relative">
               <h2 className="text-3xl font-black mb-12 text-blue-400 uppercase tracking-widest">{activeGame.name}</h2>
               {activeGame.isMulti ? (
                 <MultiplayerLobby user={user} activeGame={activeGame} showToast={showToast} />
               ) : (
                 activeGame.engine === 'react' ? <ReactionTrainer onWin={handleWin}/> :
                 activeGame.engine === 'snake' ? <SnakeGame onWin={handleWin}/> :
                 <SimXEngine game={activeGame} onWin={handleWin}/>
               )}
            </div>
          </div>
        ) : (
          <div className="space-y-12">
            <section className="bg-gradient-to-br from-blue-600 to-indigo-950 rounded-[3rem] p-10 sm:p-20 relative overflow-hidden group">
               <div className="relative z-10 max-w-xl text-center sm:text-left">
                 <h2 className="text-5xl sm:text-7xl font-black leading-none mb-6">ARCADE<br/><span className="text-blue-400">UNLOCKED.</span></h2>
                 <p className="text-blue-100/70 mb-8 font-medium">Earn coins in free modes to unlock premium simulations and multiplayer rooms.</p>
                 <button className="bg-white text-blue-950 px-10 py-4 rounded-2xl font-black hover:scale-105 transition-all shadow-2xl">START PLAYING</button>
               </div>
               <div className="absolute right-[-10%] bottom-[-10%] opacity-10 pointer-events-none group-hover:rotate-12 transition-all duration-1000 hidden sm:block"><Gamepad2 size={600}/></div>
            </section>

            <div className="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
              {ALL_GAMES.map(game => {
                const isUnlocked = unlocked.includes(game.id);
                return (
                  <div key={game.id} onClick={() => isUnlocked ? setActiveGame(game) : handleBuy(game)} 
                    className={`group relative p-8 rounded-[2.5rem] border-2 flex flex-col items-center justify-between aspect-square cursor-pointer transition-all duration-500
                      ${isUnlocked ? 'bg-slate-900 border-white/5 hover:border-blue-500/50 hover:-translate-y-2' : 'bg-slate-950 border-slate-900 grayscale opacity-60'}`}>
                    {!isUnlocked && <Lock size={16} className="absolute top-5 left-5 text-slate-700"/>}
                    <div className={`w-16 h-16 rounded-2xl flex items-center justify-center transition-all ${isUnlocked ? 'bg-slate-800 text-blue-400 group-hover:bg-blue-600 group-hover:text-white' : 'bg-slate-800 text-slate-700'}`}>
                      {game.icon}
                    </div>
                    <div className="text-center w-full">
                      <div className="text-sm font-black truncate uppercase mb-1">{game.name}</div>
                      {!isUnlocked ? (
                        <div className="text-[10px] text-yellow-500 font-black flex items-center gap-1 justify-center bg-yellow-500/10 py-1 rounded-full"><Coins size={12}/> {game.price}</div>
                      ) : (
                        <div className="text-[10px] text
